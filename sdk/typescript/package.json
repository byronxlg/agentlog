{
  "name": "agentlog-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for agentlog - a local-first decision log daemon for agentic workflows",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "logging",
    "decision-log",
    "llm",
    "agentic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/byronxlg/agentlog",
    "directory": "sdk/typescript"
  },
  "homepage": "https://github.com/byronxlg/agentlog",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
